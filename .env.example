# ============================================================
# Hardware Foundry — Environment template
# Copy to .env and fill in the values. .env is git-ignored.
# ============================================================

# ===== LLM Providers (closed-source tier) =====
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-replace-me
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# ===== Local open-source LLM (Qwen via vLLM/Ollama) =====
QWEN_BASE_URL=http://localhost:8000/v1
QWEN_API_KEY=local

# ===== LiteLLM gateway =====
LITELLM_MASTER_KEY=sk-litellm-master-dev
LITELLM_URL=http://localhost:4000

# ===== Web Search (Reference Search agent) =====
TAVILY_API_KEY=

# ===== Component APIs (Phase 3) =====
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
OCTOPART_API_KEY=
# LCSC is self-crawled (no API key needed for MVP)

# ===== Storage =====
POSTGRES_USER=foundry
POSTGRES_PASSWORD=foundry_dev_pw
POSTGRES_DB=hardware_foundry
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://foundry:foundry_dev_pw@localhost:5432/hardware_foundry

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hardware-foundry

# ===== Observability =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
SENTRY_DSN=

# ===== App / API =====
NEXT_PUBLIC_API_URL=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

# ===== Hardware tooling (Phase 4+) =====
OCTOPRINT_URL=
OCTOPRINT_API_KEY=

# ===== JLCPCB (Phase 9 — manual upload mode for MVP) =====
JLCPCB_API_KEY=

# ===== MVP single-user (Phase 12 will switch to Auth.js session) =====
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
